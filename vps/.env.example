# MK-OS VPS Hermes gateway — environment. Copy to /docker/hermes-agent-bfcq/.env on the VPS
# and fill REAL values. NEVER commit the real .env (it is gitignored). docker-compose.yml and
# the resilience scripts reference these; secrets + the webhook endpoint live here ONLY.

# Traefik / routing
TRAEFIK_HOST=srv1697659.hstgr.cloud
WEBHOOK_HOST=hermes-agent-bfcq.srv1697659.hstgr.cloud
# Obscure webhook path (defense-in-depth alongside the secret_token + Telegram-IP allowlist).
TG_WEBHOOK_PATH=/tg-hook-REPLACE_WITH_RANDOM_HEX

# Telegram webhook secret_token — generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=REPLACE_WITH_64_HEX_CHARS

# Hermes dashboard basic auth
ADMIN_USERNAME=REPLACE
ADMIN_PASSWORD=REPLACE

# NOTE: the Telegram BOT TOKEN is NOT here — it lives in ./data/.env (loaded into Hermes config).
